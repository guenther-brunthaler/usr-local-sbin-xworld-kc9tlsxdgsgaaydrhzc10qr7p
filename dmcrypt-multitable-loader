set -e
cleanup() {
	rc=$?
	test "$TD" && rm -r -- "$TD"
	test $rc = 0 || echo "\"$0\" failed!" >& 2
}
TD=
trap cleanup 0
trap 'exit $?' INT HUP QUIT TERM PIPE

unmap=false
dry_run=false
show_tables=false
while getopts snu opt
do
	case $opt in
		s) show_tables=true;;
		n) dry_run=true;;
		u) unmap=true;;
		*) false || exit
	esac
done
shift `expr $OPTIND - 1 || :`

# Portable version of "tac":
tac() {
	awk '{print NR ":" $0}' | sort -t : -k 1,1nr | cut -d : -f 2-
}

run() {
	$dry_run && set echo SIMULATION: "$@"
	"$@"
}

# Replace "*"-expression in the 2nd table field with a count of 512-byte
# sectors.
resolve_wildcard() {
	awk -f /dev/fd/5 5<< 'EO_AWK'

$3 == "crypt" && $2 ~ /^[*][0-9]*$/ {handle_crypt()}

{print}

function handle_crypt(    devblks) {
	sub(/^[*]/, "", $2); sub(/^$/, "0", $2);
	devblks = xcmd("blockdev --getsz '" $7 "'")
	$2 = subtract(subtract(devblks, $8), $2)
}

# Arbitrary precision unsigned decimal text-representation subtraction.
#
# Subtract <y> from <x>, returning the result in the same format without
# redundant leading zeros.
#
# Will abort if the result becomes negative.
function subtract(x, y    , d, i, nx, ny, borrow, result) {
	# Make <x> at least as long as <y>.
	while (length(y) > length(x)) x = "0" x
	nx = length(x); ny = length(y)
	# Subtract the digits of y from x.
	for (i = 0; i < ny; ++i) {
		if ( \
			(borrow = \
				(\
					d = substr(x, nx - i, 1) \
					- substr(y, ny - i, 1) \
					- borrow \
				) < 0 \
			) \
		) {
			d += 10
		}
		result = d result
	}
	# Process the remaining digits of x which might be affected by
	# borrow resulting from earlier digits.
	for ( ; i < nx; ++i) {
		if ( \
			(borrow = \
				(\
					d = substr(x, nx - i, 1) \
					- borrow \
				) < 0 \
			) \
		) {
			d += 10
		}
		result = d result
	}
	if (borrow) die("Cannot subtract larger " y " from smaller " x "!")
	# Remove redundant leading zeros.
	while (length(result) > 1 && substr(result, 1, 1) == "0") {
		result = substr(result, 2)
	}
	return result
}

function die(emsg) {
	print emsg > "/dev/stderr"
	exit system("false")
}

function xcmd(cmd    , result) {
	cmd | getline result
	close(cmd)
	return result
}

EO_AWK
}

report_table() {
	awk '$3 == "crypt" {gsub(/./, "?", $5)} {print}'
}

if $unmap
then
	grep -E '^[^#[:space:]]+$' \
	| tac \
	| while read m
	do
		if test -b /dev/mapper/"$m"
		then
			echo "Unmapping '$m'..." >& 2
			run dmsetup remove -- "$m"
		else
			echo "Not unmapping already-unmapped '$m'..." >& 2
		fi
		# Wait for udev to remove device mapper symlink.
		secs=3
		while test -e /dev/mapper/"$m"
		do
			sleep 1
			secs=`expr $secs - 1` || {
				# udev did not do it. Probably it is not
				# running. Remove the symlink ourselves.
				run rm /dev/mapper/"$m"
				break
			}
		done
	done
else
	TD=`mktemp -d -- "${TMPDIR:-/tmp}/${0##*/}".XXXXXXXXXX`
	# Normalize whitespace and then remove comments and empty lines from
	# standard input.
	sed -f /dev/fd/5 5<<- '======' > "$TD"/unproc
		# Normalize whitespace.
		s/[[:space:]]\{1,\}/ /g; s/^ //; s/ $//
		# Remove empty lines and comments.
		/^#/d; /^$/d
	======
	while read m < "$TD"/unproc
	do
		 sed '2,/^[^ ]*$/!d; /^[^ ]*$/d' "$TD"/unproc \
		 | tee "$TD"/table0 \
		 | resolve_wildcard > "$TD"/table
		 if $show_tables
		 then
			echo
			echo "BEGIN ORIGINAL TABLE '$m'"
			report_table < "$TD"/table0
			echo "END ORIGINAL TABLE '$m'"
			echo
			echo "BEGIN RESOLVED TABLE '$m'"
			report_table < "$TD"/table
			echo "END RESOLVED TABLE '$m'"
		 fi >& 2
		 sed '1d; 2,/^[^ ]*$/{/^[^ ]*$/p; d}' \
		 	"$TD"/unproc > "$TD"/rest
		 if test -b /dev/mapper/"$m"
		 then
		 	echo "Re-using existing mapping for $m" >& 2
		 else
		 	echo "Mapping $m" >& 2
		 	run dmsetup create $m < "$TD"/table
		 	# Wait for udev to remove device mapper symlink.
		 	secs=4 phase=1
		 	while test ! -b /dev/mapper/"$m"
		 	do
		 		sleep 1
		 		secs=`expr $secs - 1` || {
		 			test $phase = 1
		 			# udev did not do it. Probably it is
		 			# not running. Create the device node
		 			# and symlink explcitly.
		 			run dmsetup mknodes -- "$m"
		 			secs=3 phase=2
		 		}
		 	done
		 fi
		 mv -- "$TD"/rest "$TD"/unproc
	done
fi
